<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LedgerMind Excel Scanner - by Naseeruddin Mohammed</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
body { font-family: Arial; background: #0f172a; color: #fff; padding: 20px; margin: 0; }
.header { background: linear-gradient(135deg, #0ea5e9, #38bdf8); padding: 20px; border-radius: 10px; margin-bottom: 20px; text-align: center; }
.upload-box { border: 2px dashed #38bdf8; padding: 40px; text-align: center; border-radius: 10px; margin-bottom: 20px; background: rgba(16,185,129,0.1); }
button { background: #38bdf8; color: #000; padding: 12px 24px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 16px; }
#results { background: #1e293b; padding: 20px; border-radius: 10px; margin-top: 20px; }
input[type="file"] { margin: 20px 0; color: #fff; }
</style>
</head>
<body>
<div class="header">
<h1>LedgerMind Excel Scanner</h1>
<p>AI-powered fraud detection for Excel files</p>
</div>

<div class="upload-box">
<h2>Upload Your Excel/CSV File</h2>
<input type="file" id="excelFile" accept=".xlsx,.xls,.csv">
<p>Supports.xlsx,.xls,.csv files</p>
</div>

<div id="results">
<h2>Waiting for file upload...</h2>
</div>

<script>
document.getElementById('excelFile').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  
  const reader = new FileReader();
  reader.onload = function(event) {
    const data = new Uint8Array(event.target.result);
    const workbook = XLSX.read(data, {type: 'array'});
    const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
    const jsonData = XLSX.utils.sheet_to_json(firstSheet);
    
    document.getElementById('results').innerHTML = 
      '<h2>✅ File Loaded Successfully</h2>' +
      '<p><b>Sheet:</b> ' + workbook.SheetNames[0] + '</p>' +
      '<p><b>Total Rows:</b> ' + jsonData.length + '</p>' +
      '<p><b>Columns:</b> ' + Object.keys(jsonData[0] || {}).join(', ') + '</p>' +
      '<hr>' +
      '<p>Ready for AI fraud scan!</p>';
  };
  reader.readAsArrayBuffer(file);
});
</script>
</body>
</html>

