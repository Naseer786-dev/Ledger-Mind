<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LedgerMind by Naseeruddin Mohammed</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0a0e1a; color: #fff; min-height: 100vh; }
        .header { background: #0f172a; padding: 1rem 2rem; border-bottom: 1px solid #1e293b; display: flex; align-items: center; justify-content: space-between; }
        .brand { display: flex; align-items: center; gap: 0.75rem; }
        .brand-logo { width: 40px; height: 40px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem; }
        .brand-text h1 { font-size: 1.1rem; }
        .brand-text p { font-size: 0.7rem; color: #64748b; }
        .container { max-width: 1400px; margin: 0 auto; padding: 2rem; }
        .upload-section { background: #0f172a; border: 2px dashed #10b981; border-radius: 20px; padding: 3rem; text-align: center; margin-bottom: 2rem; cursor: pointer; }
        .upload-section:hover { background: rgba(16,185,129,0.05); }
        .upload-icon { font-size: 3rem; margin-bottom: 1rem; }
        .file-input { display: none; }
        .btn-upload { background: linear-gradient(135deg, #10b981, #059669); color: #fff; border: none; padding: 1rem 2.5rem; border-radius: 12px; font-size: 1rem; font-weight: 600; cursor: pointer; }
        .btn-sample { background: rgba(59,130,246,0.15); color: #3b82f6; border: 1px solid rgba(59,130,246,0.3); padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.875rem; cursor: pointer; margin-top: 1rem; }
        .file-info { margin-top: 1rem; padding: 1rem; background: rgba(16,185,129,0.1); border-radius: 10px; display: none; }
        .file-info.show { display: block; }
        .scan-progress { display: none; margin: 2rem 0; }
        .scan-progress.show { display: block; }
        .progress-bar-bg { background: rgba(255,255,255,0.1); border-radius: 10px; height: 12px; }
        .progress-bar { height: 100%; background: linear-gradient(90deg, #10b981, #06b6d4); border-radius: 10px; width: 0%; transition: width 0.5s ease; }
        .progress-text { text-align: center; margin-top: 0.75rem; color: #94a3b8; }
        .agent-status { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem; margin-top: 1rem; }
        .agent-status-item { text-align: center; padding: 0.5rem; border-radius: 8px; background: rgba(255,255,255,0.03); font-size: 0.7rem; color: #64748b; }
        .agent-status-item.active { background: rgba(16,185,129,0.15); color: #10b981; }
        .agent-status-item.done { background: rgba(16,185,129,0.2); color: #10b981; }
        .results { display: none; }
        .results.show { display: block; }
        .summary-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
        .summary-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 16px; padding: 1.5rem; text-align: center; }
        .summary-card .value { font-size: 2rem; font-weight: 800; }
        .good .value { color: #10b981; }
        .danger .value { color: #ef4444; }
        .warning .value { color: #f59e0b; }
        .info .value { color: #3b82f6; }
        .tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid #1e293b; padding-bottom: 0.5rem; overflow-x: auto; }
        .tab { padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; font-size: 0.875rem; color: #64748b; border: none; background: transparent; white-space: nowrap; }
        .tab.active { color: #fff; background: rgba(16,185,129,0.15); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
        .data-table th { text-align: left; padding: 0.75rem 1rem; color: #94a3b8; border-bottom: 1px solid #1e293b; }
        .data-table td { padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .tag { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; }
        .tag-revenue { background: rgba(16,185,129,0.15); color: #10b981; }
        .tag-expense { background: rgba(239,68,68,0.15); color: #ef4444; }
        .fraud-alert { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; }
        .deduction-card { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2); border-radius: 12px; padding: 1.25rem; margin-bottom: 1rem; display: flex; justify-content: space-between; }
        .chart-container { background: #0f172a; border: 1px solid #1e293b; border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; }
        @media (max-width: 768px) { .summary-grid { grid-template-columns: repeat(2, 1fr); } }
    </style>
</head>
<body>

<div class="header">
    <div class="brand">
        <div class="brand-logo">L</div>
        <div class="brand-text">
            <h1>LedgerMind Excel Scanner</h1>
            <p>by Naseeruddin Mohammed</p>
        </div>
    </div>
</div>

<div class="container">
    <div class="upload-section" id="uploadSection">
        <div class="upload-icon">&#128202;</div>
        <h2>Upload Your Excel or CSV File</h2>
        <p>Drag and drop your file here, or click to browse</p>
        <input type="file" id="fileInput" class="file-input" accept=".xlsx,.xls,.csv">
        <button class="btn-upload" onclick="document.getElementById('fileInput').click()">Choose File</button>
        <div><button class="btn-sample" onclick="loadSampleData()">Use Sample Data (Demo)</button></div>
        <div class="file-info" id="fileInfo">
            <span id="fileName"></span> - <span id="fileRows"></span> rows
        </div>
    </div>

    <div class="scan-progress" id="scanProgress">
        <div class="progress-bar-bg"><div class="progress-bar" id="progressBar"></div></div>
        <div class="progress-text" id="progressText">Initializing...</div>
        <div class="agent-status">
            <div class="agent-status-item" id="status-data">Data Agent</div>
            <div class="agent-status-item" id="status-fraud">Fraud Agent</div>
            <div class="agent-status-item" id="status-forecast">Forecast</div>
            <div class="agent-status-item" id="status-tax">Tax Agent</div>
            <div class="agent-status-item" id="status-vendor">Vendor</div>
        </div>
    </div>

    <div class="results" id="results">
        <div class="summary-grid">
            <div class="summary-card info"><div class="value" id="totalTx">0</div><div style="color:#64748b;font-size:0.8rem">Transactions</div></div>
            <div class="summary-card good"><div class="value" id="taxFound">$0</div><div style="color:#64748b;font-size:0.8rem">Tax Deductions</div></div>
            <div class="summary-card danger"><div class="value" id="fraudCount">0</div><div style="color:#64748b;font-size:0.8rem">Fraud Alerts</div></div>
            <div class="summary-card warning"><div class="value" id="riskLevel">Low</div><div style="color:#64748b;font-size:0.8rem">Risk Level</div></div>
        </div>

        <div class="tabs">
            <button class="tab active" onclick="switchTab('all',this)">All Transactions</button>
            <button class="tab" onclick="switchTab('fraud',this)">Fraud Alerts</button>
            <button class="tab" onclick="switchTab('tax',this)">Tax Deductions</button>
            <button class="tab" onclick="switchTab('forecast',this)">Cash Flow</button>
            <button class="tab" onclick="switchTab('vendor',this)">Vendors</button>
        </div>

        <div class="tab-content active" id="tab-all">
            <div style="overflow-x:auto"><table class="data-table"><thead><tr><th>Date</th><th>Description</th><th>Vendor</th><th>Category</th><th>Amount</th><th>Type</th><th>Status</th></tr></thead><tbody id="txTableBody"></tbody></table></div>
        </div>
        <div class="tab-content" id="tab-fraud"><div id="fraudContainer"></div></div>
        <div class="tab-content" id="tab-tax"><div id="taxContainer"></div></div>
        <div class="tab-content" id="tab-forecast"><div class="chart-container"><canvas id="cashFlowChart" height="100"></canvas></div></div>
        <div class="tab-content" id="tab-vendor"><div id="vendorContainer"></div></div>
    </div>
</div>

<script>
const SAMPLE_DATA = [
    {date:"2026-07-01",description:"Stripe Payment",vendor:"Stripe",amount:4500,type:"Revenue"},
    {date:"2026-07-02",description:"AWS Bill",vendor:"AWS",amount:-342.50,type:"Expense"},
    {date:"2026-07-03",description:"Office Paper",vendor:"OfficeMax",amount:-125,type:"Expense"},
    {date:"2026-07-05",description:"Client Invoice",vendor:"Acme Corp",amount:8200,type:"Revenue"},
    {date:"2026-07-06",description:"Slack",vendor:"Slack",amount:-15,type:"Expense"},
    {date:"2026-07-07",description:"TechSupplies Invoice 4482",vendor:"TechSupplies",amount:-12500,type:"Expense"},
    {date:"2026-07-08",description:"Uber Trip",vendor:"Uber",amount:-47.30,type:"Expense"},
    {date:"2026-07-09",description:"Google Ads",vendor:"Google",amount:-850,type:"Expense"},
    {date:"2026-07-10",description:"Client Invoice",vendor:"Beta LLC",amount:3200,type:"Revenue"},
    {date:"2026-07-11",description:"TechSupplies Invoice 4482",vendor:"TechSupplies",amount:-12500,type:"Expense"},
    {date:"2026-07-12",description:"Office Rent",vendor:"Landlord",amount:-2500,type:"Expense"},
    {date:"2026-07-13",description:"Notion",vendor:"Notion",amount:-10,type:"Expense"},
    {date:"2026-07-14",description:"Wire Transfer Unknown",vendor:"Unknown",amount:-8750,type:"Expense"},
    {date:"2026-07-15",description:"Client Invoice",vendor:"Gamma Inc",amount:5600,type:"Revenue"},
    {date:"2026-07-16",description:"Figma",vendor:"Figma",amount:-15,type:"Expense"},
    {date:"2026-07-17",description:"GitHub Pro",vendor:"GitHub",amount:-21,type:"Expense"},
    {date:"2026-07-18",description:"OfficeMax Toner",vendor:"OfficeMax",amount:-189,type:"Expense"},
    {date:"2026-07-19",description:"Client Invoice",vendor:"Delta Co",amount:7800,type:"Revenue"},
    {date:"2026-07-20",description:"Zoom",vendor:"Zoom",amount:-19.99,type:"Expense"},
    {date:"2026-07-21",description:"Business Lunch",vendor:"Restaurant",amount:-87.50,type:"Expense"},
    {date:"2026-07-22",description:"Client Invoice",vendor:"Epsilon Ltd",amount:4300,type:"Revenue"},
    {date:"2026-07-23",description:"AWS Server",vendor:"AWS",amount:-520,type:"Expense"}
];

let transactions=[], fraudAlerts=[], taxDeductions=[], vendorScores=[];

const uploadSection=document.getElementById('uploadSection');
const fileInput=document.getElementById('fileInput');

uploadSection.addEventListener('dragover',e=>{e.preventDefault();uploadSection.style.borderColor='#10b981'});
uploadSection.addEventListener('dragleave',()=>{uploadSection.style.borderColor='rgba(16,185,129,0.3)'});
uploadSection.addEventListener('drop',e=>{e.preventDefault();uploadSection.style.borderColor='rgba(16,185,129,0.3)';if(e.dataTransfer.files.length)handleFile(e.dataTransfer.files[0])});
fileInput.addEventListener('change',e=>{if(e.target.files.length)handleFile(e.target.files[0])});

function handleFile(file){
    const reader=new FileReader();
    reader.onload=function(e){
        try{
            const data=new Uint8Array(e.target.result);
            const workbook=XLSX.read(data,{type:'array'});
            const firstSheet=workbook.Sheets[workbook.SheetNames[0]];
            const jsonData=XLSX.utils.sheet_to_json(firstSheet);
            if(jsonData.length===0){alert('No data found in file');return}
            document.getElementById('fileName').textContent=file.name;
            document.getElementById('fileRows').textContent=jsonData.length;
            document.getElementById('fileInfo').classList.add('show');
            transactions=jsonData.map((row,i)=>{
                const amt=parseFloat(row.Amount||row.amount||row.Debit||0);
                return{id:'TX-'+(i+1),date:row.Date||row.date||'2026-07-01',description:row.Description||row.description||'Transaction '+(i+1),vendor:row.Vendor||row.vendor||'',amount:amt,type:amt>0?'Revenue':'Expense'};
            });
            startScan();
        }catch(err){alert('Error: '+err.message)}
    };
    reader.readAsArrayBuffer(file);
}

function loadSampleData(){
    transactions=SAMPLE_DATA.map((row,i)=>({id:'TX-'+(i+1),...row}));
    document.getElementById('fileName').textContent='Sample_Demo_Data.xlsx';
    document.getElementById('fileRows').textContent=transactions.length;
    document.getElementById('fileInfo').classList.add('show');
    startScan();
}

function startScan(){
    document.getElementById('scanProgress').classList.add('show');
    document.getElementById('uploadSection').style.display='none';
    const steps=[{pct:10,text:'Data Agent: Categorizing...',agent:'data'},{pct:30,text:'Data Agent: Reconciling...',agent:'data'},{pct:45,text:'Fraud Agent: Scanning...',agent:'fraud'},{pct:60,text:'Fraud Agent: Detecting...',agent:'fraud'},{pct:72,text:'Forecast Agent: Analyzing...',agent:'forecast'},{pct:82,text:'Tax Agent: Finding...',agent:'tax'},{pct:92,text:'Vendor Agent: Scoring...',agent:'vendor'},{pct:100,text:'Complete!',agent:'done'}];
    let step=0;
    const agentOrder=['data','fraud','forecast','tax','vendor'];
    const interval=setInterval(function(){
        if(step>=steps.length){clearInterval(interval);showResults();return}
        const s=steps[step];
        document.getElementById('progressBar').style.width=s.pct+'%';
        document.getElementById('progressText').textContent=s.text;
        if(s.agent!=='done')document.getElementById('status-'+s.agent).classList.add('active');
        const currentIdx=agentOrder.indexOf(s.agent);
        for(let i=0;i<currentIdx;i++){document.getElementById('status-'+agentOrder[i]).classList.remove('active');document.getElementById('status-'+agentOrder[i]).classList.add('done')}
        step++;
    },500);
}

function runAIAnalysis(){
    transactions.forEach(tx=>{
        const d=tx.description.toLowerCase(),v=(tx.vendor||'').toLowerCase();
        if(tx.type==='Revenue')tx.category='Revenue';
        else if(d.includes('aws')||d.includes('server')||v.includes('aws'))tx.category='Software';
        else if(['slack','notion','figma','github','zoom'].some(x=>d.includes(x)))tx.category='Software';
        else if(['office','paper','toner'].some(x=>d.includes(x)))tx.category='Office Supplies';
        else if(['uber','trip','travel'].some(x=>d.includes(x)))tx.category='Travel';
        else if(['ads','google ads','marketing'].some(x=>d.includes(x)))tx.category='Marketing';
        else if(d.includes('rent')||d.includes('landlord'))tx.category='Rent';
        else if(['lunch','restaurant','meal'].some(x=>d.includes(x)))tx.category='Meals';
        else if(d.includes('wire')||d.includes('unknown'))tx.category='Uncategorized';
        else tx.category='Other';
    });

    fraudAlerts=[];
    const seen={};
    transactions.forEach(tx=>{
        const key=tx.vendor+'-'+Math.abs(tx.amount);
        if(seen[key]&&tx.vendor&&tx.vendor!=='Unknown'){
            fraudAlerts.push({id:tx.id,type:'Duplicate Invoice',severity:'high',description:'Duplicate from '+tx.vendor+' for $'+Math.abs(tx.amount).toLocaleString(),action:'Block'});
        }else{seen[key]=tx.id}
        if(Math.abs(tx.amount)>8000&&!['Acme Corp','Beta LLC','Gamma Inc','Delta Co','Epsilon Ltd'].includes(tx.vendor)&&!fraudAlerts.find(a=>a.id===tx.id)){
            fraudAlerts.push({id:tx.id,type:'Large Amount',severity:'medium',description:'$'+Math.abs(tx.amount).toLocaleString()+' to '+tx.vendor+' is unusual',action:'Verify'});
        }
        if(tx.vendor==='Unknown'||d.includes('unknown')){
            fraudAlerts.push({id:tx.id,type:'Unknown Vendor',severity:'high',description:'Wire of $'+Math.abs(tx.amount).toLocaleString()+' to unknown',action:'Hold'});
        }
    });

    taxDeductions=[];
    transactions.forEach(tx=>{
        if(tx.type==='Expense'){
            const amt=Math.abs(tx.amount);
            if(tx.category==='Software')taxDeductions.push({category:'Software',amount:amt,description:tx.description+' - Business software',confidence:0.95});
            if(tx.category==='Travel')taxDeductions.push({category:'Travel',amount:amt,description:tx.description+' - Business travel',confidence:0.90});
            if(tx.category==='Meals')taxDeductions.push({category:'Meals',amount:amt*0.5,description:tx.description+' - Business meal (50%)',confidence:0.85});
            if(tx.category==='Marketing')taxDeductions.push({category:'Advertising',amount:amt,description:tx.description+' - Business advertising',confidence:0.95});
            if(tx.category==='Office Supplies')taxDeductions.push({category:'Office',amount:amt,description:tx.description+' - Office supplies',confidence:0.95});
        }
    });

    const vendorData={};
    transactions.forEach(tx=>{const v=tx.vendor||'Unknown';if(!vendorData[v])vendorData[v]={total:0,count:0};vendorData[v].total+=Math.abs(tx.amount);vendorData[v].count++});
    vendorScores=[];
    for(let vname in vendorData){
        const data=vendorData[vname];
        const hasFraud=fraudAlerts.some(a=>{const t=transactions.find(t=>t.id===a.id);return t&&t.vendor===vname});
        const score=hasFraud?25:Math.min(100,70+data.count*5);
        vendorScores.push({name:vname,total:data.total,count:data.count,score,hasFraud});
    }
    vendorScores.sort((a,b)=>b.total-a.total);
}

function showResults(){
    runAIAnalysis();
    document.getElementById('scanProgress').style.display='none';
    document.getElementById('results').classList.add('show');
    document.getElementById('totalTx').textContent=transactions.length;
    const totalDeductions=taxDeductions.reduce((sum,d)=>sum+d.amount,0);
    document.getElementById('taxFound').textContent='$'+totalDeductions.toLocaleString(undefined,{maximumFractionDigits:0});
    document.getElementById('fraudCount').textContent=fraudAlerts.length;
    const riskLevel=fraudAlerts.length>=3?'Critical':fraudAlerts.length>=1?'Medium':'Low';
    const riskEl=document.getElementById('riskLevel');
    riskEl.textContent=riskLevel;
    riskEl.style.color=fraudAlerts.length>=3?'#ef4444':fraudAlerts.length>=1?'#f59e0b':'#10b981';
    renderTransactions();renderFraudAlerts();renderTaxDeductions();renderCashFlow();renderVendors();
}

function renderTransactions(){
    const tbody=document.getElementById('txTableBody');
    tbody.innerHTML=transactions.map(tx=>{
        const isFraud=fraudAlerts.some(a=>a.id===tx.id);
        return '<tr style="'+(isFraud?'background:rgba(239,68,68,0.05)':'')+'"><td>'+tx.date+'</td><td>'+tx.description+'</td><td>'+tx.vendor+'</td><td><span class="tag tag-'+(tx.type==='Revenue'?'revenue':'expense')+'">'+tx.category+'</span></td><td style="color:'+(tx.amount>0?'#10b981':'#ef4444')+'">$'+Math.abs(tx.amount).toLocaleString()+'</td><td>'+tx.type+'</td><td>'+(isFraud?'<span style="color:#ef4444">Alert</span>':'<span style="color:#10b981">OK</span>')+'</td></tr>';
    }).join('');
}

function renderFraudAlerts(){
    const container=document.getElementById('fraudContainer');
    if(fraudAlerts.length===0){container.innerHTML='<div style="text-align:center;padding:3rem;color:#64748b">No fraud detected!</div>';return}
    container.innerHTML=fraudAlerts.map(a=>'<div class="fraud-alert"><h4 style="color:#fca5a5">'+a.type+'</h4><p>'+a.description+'</p><p style="color:#ef4444;font-size:0.75rem">Severity: '+a.severity.toUpperCase()+'</p></div>').join('');
}

function renderTaxDeductions(){
    const container=document.getElementById('taxContainer');
    const total=taxDeductions.reduce((sum,d)=>sum+d.amount,0);
    container.innerHTML='<div class="deduction-card"><div><h4 style="color:#6ee7b7">Total Deductions Found</h4><p style="color:#64748b">'+taxDeductions.length+' transactions</p></div><div style="font-size:1.5rem;color:#10b981;font-weight:800">$'+total.toLocaleString(undefined,{maximumFractionDigits:0})+'</div></div>'+taxDeductions.map(d=>'<div class="deduction-card"><div><p style="color:#94a3b8">'+d.description+'</p></div><div style="color:#10b981;font-weight:600">+$'+d.amount.toLocaleString(undefined,{maximumFractionDigits:2})+'</div></div>').join('');
}

function renderCashFlow(){
    let balance=50000;const labels=[],data=[];
    transactions.forEach(tx=>{balance+=tx.amount;labels.push(tx.date.slice(5));data.push(balance)});
    for(let i=1;i<=10;i++){const d=new Date();d.setDate(d.getDate()+i);labels.push((d.getMonth()+1)+'-'+d.getDate());data.push(balance+(Math.random()*2000-500))}
    new Chart(document.getElementById('cashFlowChart').getContext('2d'),{type:'line',data:{labels:labels,datasets:[{label:'Cash',data:data,borderColor:'#10b981',backgroundColor:'rgba(16,185,129,0.1)',fill:true,tension:0.4}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#64748b'}},x:{grid:{display:false},ticks:{color:'#64748b'}}}}});
}

function renderVendors(){
    const container=document.getElementById('vendorContainer');
    container.innerHTML=vendorScores.map(v=>{const color=v.score>=80?'#10b981':v.score>=50?'#f59e0b':'#ef4444';return'<div style="background:#0f172a;border:1px solid #1e293b;border-radius:12px;padding:1.25rem;margin-bottom:1rem"><div style="display:flex;justify-content:space-between;margin-bottom:0.5rem"><span style="font-weight:600">'+v.name+'</span><span style="color:'+color+'">'+v.score+'/100</span></div><div style="display:flex;gap:2rem;color:#64748b;font-size:0.8rem"><span>Total: $'+v.total.toLocaleString()+'</span><span>Count: '+v.count+'</span>'+(v.hasFraud?'<span style="color:#ef4444">Fraud Alert</span>':'<span style="color:#10b981">Clean</span>')+'</div></div>'}).join('');
}

function switchTab(tabName,btn){
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+tabName).classList.add('active');
}
</script>
</body>
</html>
