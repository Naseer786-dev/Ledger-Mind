<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LedgerMind by Naseeruddin Mohammed</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',Tahoma,sans-serif;background:#0a0e1a;color:#fff;min-height:100vh}
.header{background:#0f172a;padding:1rem 2rem;border-bottom:1px solid #1e293b;display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:0.75rem}
.brand-logo{width:40px;height:40px;background:linear-gradient(135deg,#10b981,#059669);border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.2rem;color:#fff}
.brand-text h1{font-size:1.1rem;color:#fff}
.brand-text p{font-size:0.7rem;color:#64748b}
.container{max-width:1400px;margin:0 auto;padding:2rem}
.upload-section{background:#0f172a;border:2px dashed #10b981;border-radius:20px;padding:3rem;text-align:center;margin-bottom:2rem;cursor:pointer;transition:all .3s}
.upload-section:hover{background:rgba(16,185,129,.05)}
.upload-icon{font-size:3rem;margin-bottom:1rem}
.upload-section h2{font-size:1.5rem;margin-bottom:.5rem}
.upload-section p{color:#64748b;margin-bottom:1.5rem}
.file-input{display:none}
.btn-upload{background:linear-gradient(135deg,#10b981,#059669);color:#fff;border:none;padding:1rem 2.5rem;border-radius:12px;font-size:1rem;font-weight:600;cursor:pointer;transition:all .3s}
.btn-upload:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(16,185,129,.3)}
.btn-sample{background:rgba(59,130,246,.15);color:#3b82f6;border:1px solid rgba(59,130,246,.3);padding:.6rem 1.2rem;border-radius:8px;font-size:.875rem;cursor:pointer;margin-top:1rem}
.file-info{margin-top:1rem;padding:1rem;background:rgba(16,185,129,.1);border-radius:10px;display:none;color:#10b981}
.file-info.show{display:block}
.scan-progress{display:none;margin:2rem 0}
.scan-progress.show{display:block}
.progress-bar-bg{background:rgba(255,255,255,.1);border-radius:10px;height:12px;overflow:hidden}
.progress-bar{height:100%;background:linear-gradient(90deg,#10b981,#06b6d4);border-radius:10px;width:0%;transition:width .5s ease}
.progress-text{text-align:center;margin-top:.75rem;color:#94a3b8;font-size:.875rem}
.agent-status{display:grid;grid-template-columns:repeat(5,1fr);gap:.5rem;margin-top:1rem}
.agent-status-item{text-align:center;padding:.5rem;border-radius:8px;background:rgba(255,255,255,.03);font-size:.7rem;color:#64748b}
.agent-status-item.active{background:rgba(16,185,129,.15);color:#10b981}
.agent-status-item.done{background:rgba(16,185,129,.2);color:#10b981}
.results{display:none}
.results.show{display:block}
.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem}
.summary-card{background:#0f172a;border:1px solid #1e293b;border-radius:16px;padding:1.5rem;text-align:center}
.summary-card .icon{font-size:2rem;margin-bottom:.5rem}
.summary-card .value{font-size:2rem;font-weight:800}
.summary-card .label{color:#64748b;font-size:.8rem;margin-top:.25rem}
.good .value{color:#10b981}
.danger .value{color:#ef4444}
.warning .value{color:#f59e0b}
.info .value{color:#3b82f6}
.tabs{display:flex;gap:.5rem;margin-bottom:1.5rem;border-bottom:1px solid #1e293b;padding-bottom:.5rem;overflow-x:auto}
.tab{padding:.6rem 1.2rem;border-radius:8px;cursor:pointer;font-size:.875rem;font-weight:500;color:#64748b;border:none;background:transparent;white-space:nowrap;transition:all .2s}
.tab:hover{color:#fff;background:rgba(255,255,255,.05)}
.tab.active{color:#fff;background:rgba(16,185,129,.15)}
.tab-content{display:none}
.tab-content.active{display:block}
.data-table{width:100%;border-collapse:collapse;font-size:.875rem}
.data-table th{text-align:left;padding:.75rem 1rem;color:#94a3b8;font-weight:500;border-bottom:1px solid #1e293b}
.data-table td{padding:.75rem 1rem;border-bottom:1px solid rgba(255,255,255,.04);color:#e2e8f0}
.data-table tr:hover td{background:rgba(255,255,255,.02)}
.tag{display:inline-block;padding:.2rem .6rem;border-radius:6px;font-size:.75rem;font-weight:500}
.tag-revenue{background:rgba(16,185,129,.15);color:#10b981}
.tag-expense{background:rgba(239,68,68,.15);color:#ef4444}
.tag-software{background:rgba(59,130,246,.15);color:#3b82f6}
.tag-office{background:rgba(245,158,11,.15);color:#f59e0b}
.tag-travel{background:rgba(139,92,246,.15);color:#a855f7}
.tag-marketing{background:rgba(236,72,153,.15);color:#ec4899}
.tag-uncategorized{background:rgba(100,116,139,.15);color:#64748b}
.fraud-alert{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:1.25rem;margin-bottom:1rem}
.fraud-alert h4{color:#fca5a5;font-size:1rem;margin-bottom:.5rem}
.fraud-alert p{color:#94a3b8;font-size:.875rem;line-height:1.5}
.fraud-alert .severity{color:#ef4444;font-size:.75rem;margin-top:.5rem}
.deduction-card{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);border-radius:12px;padding:1.25rem;margin-bottom:1rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.deduction-info h4{color:#6ee7b7;font-size:1rem}
.deduction-info p{color:#94a3b8;font-size:.8rem;margin-top:.25rem}
.deduction-amount{font-size:1.5rem;font-weight:800;color:#10b981}
.chart-container{background:#0f172a;border:1px solid #1e293b;border-radius:16px;padding:1.5rem;margin-bottom:1.5rem}
.chart-container h3{font-size:1rem;margin-bottom:1rem;color:#fff}
.vendor-card{background:#0f172a;border:1px solid #1e293b;border-radius:12px;padding:1.25rem;margin-bottom:1rem}
.vendor-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem}
.vendor-name{font-weight:600;color:#fff}
.vendor-score{display:flex;align-items:center;gap:.5rem}
.score-bar{width:80px;height:6px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden}
.score-fill{height:100%;border-radius:3px}
.empty-state{text-align:center;padding:3rem;color:#64748b}
@media(max-width:768px){.summary-grid{grid-template-columns:repeat(2,1fr)}.agent-status{grid-template-columns:repeat(3,1fr)}.container{padding:1rem}}
</style>
<base target="_blank">
</head>
<body>

<div class="header">
<div class="brand">
<div class="brand-logo">L</div>
<div class="brand-text">
<h1>LedgerMind Excel Scanner</h1>
<p>by Naseeruddin Mohammed</p>
</div>
</div>
<div style="display:flex;align-items:center;gap:.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);padding:.4rem 1rem;border-radius:999px">
<div style="width:8px;height:8px;background:#10b981;border-radius:50%;animation:pulse 2s infinite"></div>
<span style="font-size:.75rem;color:#10b981;font-weight:500">5 AI Agents Ready</span>
</div>
</div>

<div class="container">

<div class="upload-section" id="uploadSection">
<div class="upload-icon">&#128202;</div>
<h2>Upload Your Excel or CSV File</h2>
<p>Drag and drop your file here, or click to browse. We scan with 5 AI agents.</p>
<input type="file" id="fileInput" class="file-input" accept=".xlsx,.xls,.csv">
<button class="btn-upload" onclick="document.getElementById('fileInput').click()">Choose File</button>
<div><button class="btn-sample" onclick="loadSampleData()">Use Sample Data (Demo)</button></div>
<div class="file-info" id="fileInfo">
<span id="fileName"></span> - <span id="fileRows"></span> rows detected
</div>
</div>

<div class="scan-progress" id="scanProgress">
<div class="progress-bar-bg"><div class="progress-bar" id="progressBar"></div></div>
<div class="progress-text" id="progressText">Initializing AI agents...</div>
<div class="agent-status">
<div class="agent-status-item" id="status-data">Data Agent</div>
<div class="agent-status-item" id="status-fraud">Fraud Agent</div>
<div class="agent-status-item" id="status-forecast">Forecast</div>
<div class="agent-status-item" id="status-tax">Tax Agent</div>
<div class="agent-status-item" id="status-vendor">Vendor</div>
</div>
</div>

<div class="results" id="results">
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem">
<h2 style="font-size:1.5rem">AI Scan Results</h2>
<div style="background:linear-gradient(135deg,#10b981,#059669);padding:.5rem 1.5rem;border-radius:999px;font-size:.875rem;font-weight:600">Scan Complete</div>
</div>

<div class="summary-grid">
<div class="summary-card info">
<div class="icon">&#128196;</div>
<div class="value" id="totalTx">0</div>
<div class="label">Transactions Scanned</div>
</div>
<div class="summary-card good">
<div class="icon">&#128176;</div>
<div class="value" id="taxFound">$0</div>
<div class="label">Tax Deductions Found</div>
</div>
<div class="summary-card danger">
<div class="icon">&#128680;</div>
<div class="value" id="fraudCount">0</div>
<div class="label">Fraud Alerts</div>
</div>
<div class="summary-card warning">
<div class="icon">&#9888;&#65039;</div>
<div class="value" id="riskLevel">Low</div>
<div class="label">Overall Risk</div>
</div>
</div>

<div class="tabs">
<button class="tab active" onclick="switchTab('all',this)">All Transactions</button>
<button class="tab" onclick="switchTab('fraud',this)">Fraud Alerts</button>
<button class="tab" onclick="switchTab('tax',this)">Tax Deductions</button>
<button class="tab" onclick="switchTab('forecast',this)">Cash Flow</button>
<button class="tab" onclick="switchTab('vendor',this)">Vendors</button>
</div>

<div class="tab-content active" id="tab-all">
<div style="overflow-x:auto">
<table class="data-table">
<thead><tr><th>Date</th><th>Description</th><th>Vendor</th><th>Category</th><th>Amount</th><th>Type</th><th>Status</th></tr></thead>
<tbody id="txTableBody"></tbody>
</table>
</div>
</div>

<div class="tab-content" id="tab-fraud"><div id="fraudContainer"></div></div>
<div class="tab-content" id="tab-tax"><div id="taxContainer"></div></div>
<div class="tab-content" id="tab-forecast"><div class="chart-container"><canvas id="cashFlowChart" height="100"></canvas></div><div id="cashFlowAlerts"></div></div>
<div class="tab-content" id="tab-vendor"><div id="vendorContainer"></div></div>

</div>
</div>

<script>
const SAMPLE_DATA=[
{date:"2026-07-01",description:"Stripe - Customer Payment",vendor:"Stripe",amount:4500,type:"Revenue"},
{date:"2026-07-02",description:"Amazon Web Services",vendor:"AWS",amount:-342.50,type:"Expense"},
{date:"2026-07-03",description:"Office Supplies - Paper",vendor:"OfficeMax",amount:-125,type:"Expense"},
{date:"2026-07-05",description:"Client Invoice 4421",vendor:"Acme Corp",amount:8200,type:"Revenue"},
{date:"2026-07-06",description:"Slack Subscription",vendor:"Slack",amount:-15,type:"Expense"},
{date:"2026-07-07",description:"TechSupplies Inc - Invoice 4482",vendor:"TechSupplies",amount:-12500,type:"Expense"},
{date:"2026-07-08",description:"Uber - Business Trip",vendor:"Uber",amount:-47.30,type:"Expense"},
{date:"2026-07-09",description:"Google Ads Campaign",vendor:"Google",amount:-850,type:"Expense"},
{date:"2026-07-10",description:"Client Invoice 4422",vendor:"Beta LLC",amount:3200,type:"Revenue"},
{date:"2026-07-11",description:"TechSupplies Inc - Invoice 4482",vendor:"TechSupplies",amount:-12500,type:"Expense"},
{date:"2026-07-12",description:"Office Rent",vendor:"Landlord",amount:-2500,type:"Expense"},
{date:"2026-07-13",description:"Notion Subscription",vendor:"Notion",amount:-10,type:"Expense"},
{date:"2026-07-14",description:"Wire Transfer - Unknown Vendor",vendor:"Unknown",amount:-8750,type:"Expense"},
{date:"2026-07-15",description:"Client Invoice 4423",vendor:"Gamma Inc",amount:5600,type:"Revenue"},
{date:"2026-07-16",description:"Figma Subscription",vendor:"Figma",amount:-15,type:"Expense"},
{date:"2026-07-17",description:"GitHub Pro",vendor:"GitHub",amount:-21,type:"Expense"},
{date:"2026-07-18",description:"OfficeMax - Toner",vendor:"OfficeMax",amount:-189,type:"Expense"},
{date:"2026-07-19",description:"Client Invoice 4424",vendor:"Delta Co",amount:7800,type:"Revenue"},
{date:"2026-07-20",description:"Zoom Subscription",vendor:"Zoom",amount:-19.99,type:"Expense"},
{date:"2026-07-21",description:"Business Lunch",vendor:"Restaurant",amount:-87.50,type:"Expense"},
{date:"2026-07-22",description:"Client Invoice 4425",vendor:"Epsilon Ltd",amount:4300,type:"Revenue"},
{date:"2026-07-23",description:"AWS - Server Costs",vendor:"AWS",amount:-520,type:"Expense"}
];

let transactions=[],fraudAlerts=[],taxDeductions=[],vendorScores=[];
const uploadSection=document.getElementById('uploadSection');
const fileInput=document.getElementById('fileInput');

uploadSection.addEventListener('dragover',e=>{e.preventDefault();uploadSection.style.borderColor='#10b981'});
uploadSection.addEventListener('dragleave',()=>{uploadSection.style.borderColor='#10b981'});
uploadSection.addEventListener('drop',e=>{e.preventDefault();uploadSection.style.borderColor='#10b981';if(e.dataTransfer.files.length)handleFile(e.dataTransfer.files[0])});
fileInput.addEventListener('change',e=>{if(e.target.files.length)handleFile(e.target.files[0])});

function handleFile(file){
const reader=new FileReader();
reader.onload=function(e){
try{
const data=new Uint8Array(e.target.result);
const workbook=XLSX.read(data,{type:'array'});
const firstSheet=workbook.Sheets[workbook.SheetNames[0]];
const jsonData=XLSX.utils.sheet_to_json(firstSheet);
if(jsonData.length===0){alert('No data found in file. Please check format.');return}
document.getElementById('fileName').textContent=file.name;
document.getElementById('fileRows').textContent=jsonData.length;
document.getElementById('fileInfo').classList.add('show');
transactions=jsonData.map((row,i)=>{
const amt=parseFloat(row.Amount||row.amount||row.Debit||0);
return{id:'TX-'+(i+1),date:row.Date||row.date||'2026-07-01',description:row.Description||row.description||'Transaction '+(i+1),vendor:row.Vendor||row.vendor||'',amount:amt,type:amt>0?'Revenue':'Expense'}
});
startScan();
}catch(err){alert('Error reading file: '+err.message)}
};
reader.readAsArrayBuffer(file);
}

function loadSampleData(){
transactions=SAMPLE_DATA.map((row,i)=>({id:'TX-'+(i+1),...row}));
document.getElementById('fileName').textContent='Sample_Demo_Data.xlsx';
document.getElementById('fileRows').textContent=transactions.length;
document.getElementById('fileInfo').classList.add('show');
startScan();
}

function startScan(){
document.getElementById('scanProgress').classList.add('show');
document.getElementById('uploadSection').style.display='none';
const steps=[{pct:10,text:'Data Agent: Categorizing transactions...',agent:'data'},{pct:30,text:'Data Agent: Reconciling accounts...',agent:'data'},{pct:45,text:'Fraud Agent: Scanning for duplicates...',agent:'fraud'},{pct:60,text:'Fraud Agent: Detecting anomalies...',agent:'fraud'},{pct:72,text:'Forecast Agent: Analyzing cash flow...',agent:'forecast'},{pct:82,text:'Tax Agent: Finding deductions...',agent:'tax'},{pct:92,text:'Vendor Agent: Scoring suppliers...',agent:'vendor'},{pct:100,text:'All agents complete! Generating report...',agent:'done'}];
let step=0;
const agentOrder=['data','fraud','forecast','tax','vendor'];
const interval=setInterval(function(){
if(step>=steps.length){clearInterval(interval);showResults();return}
const s=steps[step];
document.getElementById('progressBar').style.width=s.pct+'%';
document.getElementById('progressText').textContent=s.text;
if(s.agent!=='done')document.getElementById('status-'+s.agent).classList.add('active');
const currentIdx=agentOrder.indexOf(s.agent);
for(let i=0;i<currentIdx;i++){document.getElementById('status-'+agentOrder[i]).classList.remove('active');document.getElementById('status-'+agentOrder[i]).classList.add('done')}
step++;
},500);
}

function runAIAnalysis(){
transactions.forEach(tx=>{
const d=tx.description.toLowerCase(),v=(tx.vendor||'').toLowerCase();
if(tx.type==='Revenue')tx.category='Revenue';
else if(d.includes('aws')||d.includes('server')||v.includes('aws'))tx.category='Software';
else if(['slack','notion','figma','github','zoom'].some(x=>d.includes(x)))tx.category='Software';
else if(['office','paper','toner'].some(x=>d.includes(x)))tx.category='Office Supplies';
else if(['uber','trip','travel'].some(x=>d.includes(x)))tx.category='Travel';
else if(['ads','google ads','marketing'].some(x=>d.includes(x)))tx.category='Marketing';
else if(d.includes('rent')||d.includes('landlord'))tx.category='Rent';
else if(['lunch','restaurant','meal'].some(x=>d.includes(x)))tx.category='Meals';
else if(d.includes('wire')||d.includes('unknown'))tx.category='Uncategorized';
else tx.category='Other';
});

fraudAlerts=[];
const seen={};
transactions.forEach(tx=>{
const key=tx.vendor+'-'+Math.abs(tx.amount);
if(seen[key]&&tx.vendor&&tx.vendor!=='Unknown'){
fraudAlerts.push({id:tx.id,type:'Duplicate Invoice',severity:'high',description:'Invoice from "'+tx.vendor+'" for $'+Math.abs(tx.amount).toLocaleString()+' appears to be a duplicate of transaction '+seen[key],action:'Block Payment'});
}else{seen[key]=tx.id}
if(Math.abs(tx.amount)>8000&&!['Acme Corp','Beta LLC','Gamma Inc','Delta Co','Epsilon Ltd',''].includes(tx.vendor)&&!fraudAlerts.find(a=>a.id===tx.id)){
fraudAlerts.push({id:tx.id,type:'Large Amount Alert',severity:'medium',description:'Transaction of $'+Math.abs(tx.amount).toLocaleString()+' to "'+tx.vendor+'" is unusually large',action:'Verify by Phone'});
}
if(tx.vendor==='Unknown'||tx.description.toLowerCase().includes('unknown')){
if(!fraudAlerts.find(a=>a.id===tx.id))fraudAlerts.push({id:tx.id,type:'Unknown Vendor',severity:'high',description:'Wire transfer of $'+Math.abs(tx.amount).toLocaleString()+' to unknown recipient',action:'Hold for Review'});
}
});

taxDeductions=[];
transactions.forEach(tx=>{
if(tx.type==='Expense'||tx.amount<0){
const amt=Math.abs(tx.amount);
if(tx.category==='Software')taxDeductions.push({category:'Software & Technology',amount:amt,description:tx.description+' - Business software subscription',confidence:0.95});
if(tx.category==='Travel')taxDeductions.push({category:'Travel & Transportation',amount:amt,description:tx.description+' - Business travel',confidence:0.90});
if(tx.category==='Meals')taxDeductions.push({category:'Meals & Entertainment',amount:amt*0.5,description:tx.description+' - Business meal (50% deductible)',confidence:0.85});
if(tx.category==='Marketing')taxDeductions.push({category:'Advertising',amount:amt,description:tx.description+' - Business advertising',confidence:0.95});
if(tx.category==='Office Supplies')taxDeductions.push({category:'Office Expenses',amount:amt,description:tx.description+' - Office supplies',confidence:0.95});
if(tx.category==='Rent')taxDeductions.push({category:'Rent',amount:amt,description:tx.description+' - Business rent',confidence:0.98});
}
});

const vendorData={};
transactions.forEach(tx=>{
const v=tx.vendor||'Unknown';
if(!vendorData[v])vendorData[v]={total:0,count:0};
vendorData[v].total+=Math.abs(tx.amount);
vendorData[v].count++;
});
vendorScores=[];
for(let vname in vendorData){
if(vendorData.hasOwnProperty(vname)){
const data=vendorData[vname];
const hasFraud=fraudAlerts.some(a=>{const t=transactions.find(t=>t.id===a.id);return t&&t.vendor===vname});
const score=hasFraud?25:Math.min(100,70+data.count*5);
vendorScores.push({name:vname,total:data.total,count:data.count,score,hasFraud});
}
}
vendorScores.sort((a,b)=>b.total-a.total);
}

function showResults(){
runAIAnalysis();
document.getElementById('scanProgress').style.display='none';
document.getElementById('results').classList.add('show');
document.getElementById('totalTx').textContent=transactions.length;
const totalDeductions=taxDeductions.reduce((sum,d)=>sum+d.amount,0);
document.getElementById('taxFound').textContent='$'+totalDeductions.toLocaleString(undefined,{maximumFractionDigits:0});
document.getElementById('fraudCount').textContent=fraudAlerts.length;
const riskLevel=fraudAlerts.length>=3?'Critical':fraudAlerts.length>=1?'Medium':'Low';
const riskEl=document.getElementById('riskLevel');
riskEl.textContent=riskLevel;
riskEl.style.color=fraudAlerts.length>=3?'#ef4444':fraudAlerts.length>=1?'#f59e0b':'#10b981';
renderTransactions();renderFraudAlerts();renderTaxDeductions();renderCashFlow();renderVendors();
}

function renderTransactions(){
const tbody=document.getElementById('txTableBody');
tbody.innerHTML=transactions.map(tx=>{
const isFraud=fraudAlerts.some(a=>a.id===tx.id);
let catClass='tag-other';
if(tx.category==='Revenue')catClass='tag-revenue';
else if(tx.category==='Software')catClass='tag-software';
else if(tx.category==='Office Supplies')catClass='tag-office';
else if(tx.category==='Travel')catClass='tag-travel';
else if(tx.category==='Marketing')catClass='tag-marketing';
else if(tx.category==='Uncategorized')catClass='tag-uncategorized';
return'<tr style="'+(isFraud?'background:rgba(239,68,68,0.05)':'')+'"><td>'+tx.date+'</td><td>'+tx.description+'</td><td>'+tx.vendor+'</td><td><span class="tag '+catClass+'">'+tx.category+'</span></td><td style="color:'+(tx.amount>0?'#10b981':'#ef4444')+';font-weight:600">'+(tx.amount>0?'+':'')+'$'+Math.abs(tx.amount).toLocaleString()+'</td><td><span class="tag '+(tx.type==='Revenue'?'tag-revenue':'tag-expense')+'">'+tx.type+'</span></td><td>'+(isFraud?'<span style="color:#ef4444;font-weight:600">&#128680; Alert</span>':'<span style="color:#10b981">&#10003; OK</span>')+'</td></tr>';
}).join('');
}

function renderFraudAlerts(){
const container=document.getElementById('fraudContainer');
if(fraudAlerts.length===0){container.innerHTML='<div class="empty-state">&#127881; No fraud detected! Your books look clean.</div>';return}
container.innerHTML=fraudAlerts.map(a=>'<div class="fraud-alert"><h4>&#128680; '+a.type+'</h4><p>'+a.description+'</p><p class="severity">Severity: '+a.severity.toUpperCase()+' | Action: '+a.action+'</p></div>').join('');
}

function renderTaxDeductions(){
const container=document.getElementById('taxContainer');
const total=taxDeductions.reduce((sum,d)=>sum+d.amount,0);
container.innerHTML='<div class="deduction-card" style="background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(6,182,212,0.1))"><div class="deduction-info"><h4>Total Tax Deductions Found</h4><p style="color:#64748b">Across '+taxDeductions.length+' transactions this period</p></div><div class="deduction-amount">$'+total.toLocaleString(undefined,{maximumFractionDigits:0})+'</div></div>'+taxDeductions.map(d=>'<div class="deduction-card"><div class="deduction-info"><p style="color:#94a3b8">'+d.description+'</p><p style="color:#64748b;font-size:0.75rem;margin-top:0.25rem">Confidence: '+(d.confidence*100).toFixed(0)+'%</p></div><div class="deduction-amount" style="font-size:1.2rem">+$'+d.amount.toLocaleString(undefined,{maximumFractionDigits:2})+'</div></div>').join('');
}

function renderCashFlow(){
let balance=50000;const labels=[],data=[];
transactions.forEach(tx=>{balance+=tx.amount;labels.push(tx.date.slice(5));data.push(balance)});
const lastBalance=data[data.length-1]||50000;
for(let i=1;i<=10;i++){const d=new Date();d.setDate(d.getDate()+i);labels.push((d.getMonth()+1)+'-'+d.getDate());data.push(lastBalance+(Math.random()*2000-500))}
new Chart(document.getElementById('cashFlowChart').getContext('2d'),{type:'line',data:{labels:labels,datasets:[{label:'Cash Balance',data:data,borderColor:'#10b981',backgroundColor:'rgba(16,185,129,0.1)',fill:true,tension:0.4,pointRadius:3}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{grid:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#64748b'}},x:{grid:{display:false},ticks:{color:'#64748b'}}}}});
const minBalance=Math.min(...data);
document.getElementById('cashFlowAlerts').innerHTML='<div style="padding:1rem;background:'+(minBalance<30000?'rgba(239,68,68,0.1)':'rgba(16,185,129,0.1)')+';border-radius:12px;border:1px solid '+(minBalance<30000?'rgba(239,68,68,0.3)':'rgba(16,185,129,0.3)')+'"><p style="color:'+(minBalance<30000?'#fca5a5':'#6ee7b7')+';font-weight:600">'+(minBalance<30000?'&#9888;&#65039; Cash Crunch Predicted':'&#10003; Cash Flow Healthy')+'</p><p style="color:#94a3b8;font-size:0.875rem;margin-top:0.5rem">'+(minBalance<30000?'Projected low: $'+minBalance.toLocaleString()+'. Recommend delaying vendor payments by 5 days.':'Lowest projected balance: $'+minBalance.toLocaleString()+'. You are in good shape.')+'</p></div>';
}

function renderVendors(){
const container=document.getElementById('vendorContainer');
container.innerHTML=vendorScores.map(v=>{const color=v.score>=80?'#10b981':v.score>=50?'#f59e0b':'#ef4444';return'<div class="vendor-card"><div class="vendor-header"><span class="vendor-name">'+v.name+'</span><div class="vendor-score"><span style="font-size:0.8rem;color:'+color+';font-weight:600">'+v.score+'/100</span><div class="score-bar"><div class="score-fill" style="width:'+v.score+'%;background:'+color+'"></div></div></div></div><div style="display:flex;gap:2rem;color:#64748b;font-size:0.8rem;flex-wrap:wrap"><span>Total Spent: $'+v.total.toLocaleString()+'</span><span>Transactions: '+v.count+'</span>'+(v.hasFraud?'<span style="color:#ef4444">&#128680; Fraud Alert</span>':'<span style="color:#10b981">&#10003; Clean</span>')+'</div></div>'}).join('');
}

function switchTab(tabName,btn){
document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
btn.classList.add('active');
document.getElementById('tab-'+tabName).classList.add('active');
}
</script>
</body>
</html>
